{
  "simulation_title": "波斯灣衝突蒙地卡羅模擬",
  "simulation_description": "這是一個從零開始建構的蒙地卡羅模擬系統，旨在評估在各種隨機條件下，美國與伊朗在波斯灣衝突中取得優勢的可能性。此模型將部隊實力參數化、地形影響量化、勝負條件明確定義，並通過數百次模擬觀察結果分佈。",
  "simulation_settings": {
    "turn_duration_hours": 12,
    "max_turns": 60,
    "monte_carlo_runs": 200,
    "victory_conditions": [
      {"name": "US_air_superiority", "side": "US", "min_days": 3, "description": "成功壓制伊朗防空系統，美軍取得空中優勢"},
      {"name": "Iran_blockade_success", "side": "Iran", "min_days": 7, "description": "霍爾木茲海峽被成功封鎖，美軍補給受阻"},
      {"name": "US_naval_destruction", "side": "Iran", "min_strength_ratio": 0.3, "description": "美軍航母或主力艦隊戰力損失超過70%"},
      {"name": "Iran_missile_eradicated", "side": "US", "min_strength_ratio": 0.2, "description": "伊朗80%以上彈道飛彈與巡弋飛彈發射能力被摧毀"},
      {"name": "US_supply_collapse", "side": "US", "threshold": 0.2, "description": "美軍平均補給低於門檻"},
      {"name": "Iran_supply_collapse", "side": "Iran", "threshold": 0.2, "description": "伊朗平均補給低於門檻"},
      {"name": "US_moral_collapse", "side": "US", "threshold": 0.3, "description": "美軍平均士氣低於門檻"},
      {"name": "Iran_moral_collapse", "side": "Iran", "threshold": 0.3, "description": "伊朗平均士氣低於門檻"},
      {"name": "Stalemate_30_days", "side": "Draw", "min_days": 30, "description": "任何一方未在30天內達成勝利條件"}
    ]
  },
