---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category } = Astro.props;

const categoryColors: Record<string, string> = {
  投資: 'badge-投資',
  科技: 'badge-科技',
  生活: 'badge-生活',
  策略: 'badge-策略',
};
const badgeClass = categoryColors[category ?? ''] ?? 'badge-其他';
---

<html lang="zh-TW">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main>
      <article class="post-container">
        {heroImage && (
          <div class="hero-image">
            <Image width={1020} height={460} src={heroImage} alt={title} />
          </div>
        )}

        <div class="post-header">
          {category && <span class={`badge ${badgeClass}`}>{category}</span>}
          <h1>{title}</h1>
          <div class="post-meta">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span class="updated">· 更新於 <FormattedDate date={updatedDate} /></span>
            )}
          </div>
        </div>

        <div class="prose">
          <slot />
        </div>

        <div class="post-footer">
          <a href="/blog" class="back-link">← 返回文章列表</a>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  .post-container {
    max-width: 760px;
    margin: 0 auto;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    margin-bottom: 2em;
    box-shadow: var(--box-shadow);
  }

  .post-header {
    margin-bottom: 2.5em;
    padding-bottom: 1.5em;
    border-bottom: 1px solid var(--border);
  }

  .badge {
    display: inline-block;
    padding: 0.25em 0.8em;
    border-radius: 4px;
    font-size: 0.8em;
    font-weight: 600;
    margin-bottom: 0.8em;
  }

  .post-header h1 {
    font-size: 2.2em;
    line-height: 1.25;
    margin: 0 0 0.5em;
    letter-spacing: -0.02em;
  }

  .post-meta {
    color: rgb(var(--gray));
    font-size: 0.9em;
  }

  .updated {
    font-style: italic;
  }

  .prose {
    line-height: 1.9;
    font-size: 1.05em;
  }

  .prose :global(h2) {
    font-size: 1.5em;
    margin-top: 2.5em;
    margin-bottom: 0.8em;
    padding-bottom: 0.3em;
    border-bottom: 2px solid var(--accent-light);
  }

  .prose :global(h3) {
    font-size: 1.2em;
    margin-top: 2em;
  }

  .prose :global(img) {
    border-radius: 10px;
    box-shadow: var(--box-shadow);
  }

  .post-footer {
    margin-top: 3em;
    padding-top: 1.5em;
    border-top: 1px solid var(--border);
  }

  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95em;
  }

  .back-link:hover {
    color: var(--accent-dark);
  }

  @media (max-width: 768px) {
    .post-header h1 { font-size: 1.7em; }
  }
</style>
