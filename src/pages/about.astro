---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead title={`關於 | ${SITE_TITLE}`} description="關於 Alpha Huang 與這個部落格" />
  </head>
  <body>
    <Header />
    <main>
      <div class="about-container">
        <div class="about-header">
          <div class="avatar">α</div>
          <div>
            <h1>Alpha Huang</h1>
            <p class="tagline">投資者 · 技術愛好者 · 策略思考者</p>
          </div>
        </div>

        <div class="prose">
          <h2>關於這個部落格</h2>
          <p>
            Alpha Notes 是我記錄思考的地方。內容涵蓋美股投資策略、科技趨勢觀察、
            AI 應用探索，以及日常生活的雜感。
          </p>
          <p>
            寫作對我來說是一種整理思緒的方式。把想法寫下來，才能看清楚它是否真的站得住腳。
          </p>

          <h2>關注領域</h2>
          <ul>
            <li><strong>投資</strong> — 美股、量化策略、總體經濟分析</li>
            <li><strong>科技</strong> — AI 應用、自動化工具、軟體開發</li>
            <li><strong>策略</strong> — 博弈思維、決策框架、情境推演</li>
            <li><strong>生活</strong> — 效率工具、學習方法、隨筆雜記</li>
          </ul>

          <h2>聯絡</h2>
          <p>
            可以在 <a href="https://github.com/bargisula" target="_blank">GitHub</a> 找到我。
          </p>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .about-container {
    max-width: 720px;
    margin: 0 auto;
  }

  .about-header {
    display: flex;
    align-items: center;
    gap: 1.5em;
    margin-bottom: 2em;
    padding: 2em;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
  }

  .avatar {
    width: 72px;
    height: 72px;
    min-width: 72px;
    background: var(--accent);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2em;
    font-weight: 700;
  }

  .about-header h1 {
    font-size: 1.6em;
    margin: 0 0 0.2em;
  }

  .tagline {
    color: rgb(var(--gray));
    margin: 0;
    font-size: 0.95em;
  }

  .prose {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2em 2.5em;
  }

  .prose h2 {
    font-size: 1.2em;
    margin-top: 2em;
    padding-bottom: 0.4em;
    border-bottom: 2px solid var(--accent-light);
  }

  .prose h2:first-child {
    margin-top: 0;
  }

  .prose ul {
    padding-left: 1.2em;
  }

  .prose li {
    margin-bottom: 0.4em;
  }

  @media (max-width: 560px) {
    .about-header { flex-direction: column; text-align: center; }
    .prose { padding: 1.5em; }
  }
</style>
