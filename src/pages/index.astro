---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const categoryColors: Record<string, string> = {
  投資: 'badge-投資',
  科技: 'badge-科技',
  生活: 'badge-生活',
  策略: 'badge-策略',
};
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="hero-badge">個人隨筆</div>
        <h1>Alpha Notes</h1>
        <p class="hero-desc">關於投資策略、科技觀察與日常生活的記錄。<br />寫下思考，留住當下。</p>
        <div class="hero-actions">
          <a href="/blog" class="btn-primary">閱讀文章</a>
          <a href="/about" class="btn-secondary">關於我</a>
        </div>
      </section>

      <!-- Recent Posts -->
      <section class="posts-section">
        <div class="section-header">
          <h2>最新文章</h2>
          <a href="/blog" class="view-all">查看全部 →</a>
        </div>

        <div class="card-grid">
          {posts.map((post) => {
            const category = (post.data as any).category ?? '其他';
            const badgeClass = categoryColors[category] ?? 'badge-其他';
            return (
              <article class="card">
                <a href={`/blog/${post.id}/`} class="card-link">
                  {(post.data as any).heroImage && (
                    <div class="card-image">
                      <img src={(post.data as any).heroImage.src} alt={post.data.title} loading="lazy" />
                    </div>
                  )}
                  <div class="card-body">
                    <span class={`badge ${badgeClass}`}>{category}</span>
                    <h3 class="card-title">{post.data.title}</h3>
                    <p class="card-desc">{post.data.description}</p>
                    <time class="card-date">
                      <FormattedDate date={post.data.pubDate} />
                    </time>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .hero {
    text-align: center;
    padding: 4em 1em 3em;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.3em 1em;
    background: var(--accent-light);
    color: var(--accent);
    border-radius: 20px;
    font-size: 0.85em;
    font-weight: 600;
    margin-bottom: 1em;
    letter-spacing: 0.05em;
  }

  .hero h1 {
    font-size: 3em;
    margin: 0 0 0.4em;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, rgb(var(--black)) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    color: rgb(var(--gray));
    font-size: 1.1em;
    line-height: 1.8;
    margin: 0 auto 1.8em;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: 1em;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 0.7em 1.8em;
    background: var(--accent);
    color: white;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    background: var(--accent-dark);
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
  }

  .btn-secondary {
    padding: 0.7em 1.8em;
    border: 1.5px solid var(--border);
    color: rgb(var(--gray-dark));
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .posts-section {
    padding: 1em 0 2em;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5em;
  }

  .section-header h2 {
    font-size: 1.4em;
    margin: 0;
  }

  .view-all {
    font-size: 0.9em;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .view-all:hover {
    color: var(--accent-dark);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.2s;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--box-shadow-hover);
    border-color: transparent;
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .card-image img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 0;
    display: block;
  }

  .card-body {
    padding: 1.2em 1.4em 1.4em;
  }

  .badge {
    display: inline-block;
    padding: 0.2em 0.7em;
    border-radius: 4px;
    font-size: 0.75em;
    font-weight: 600;
    margin-bottom: 0.7em;
  }

  .card-title {
    font-size: 1.05em;
    font-weight: 700;
    margin: 0 0 0.5em;
    line-height: 1.4;
    color: rgb(var(--black));
  }

  .card-desc {
    font-size: 0.88em;
    color: rgb(var(--gray));
    margin: 0 0 1em;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-date {
    font-size: 0.8em;
    color: rgb(var(--gray));
  }

  @media (max-width: 900px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
    .hero h1 { font-size: 2.2em; }
  }

  @media (max-width: 560px) {
    .card-grid { grid-template-columns: 1fr; }
    .hero h1 { font-size: 1.8em; }
  }
</style>
