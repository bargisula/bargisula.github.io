---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <a href="/" class="logo">
      <span class="logo-icon">α</span>
      <span class="logo-text">{SITE_TITLE}</span>
    </a>
    <div class="nav-links">
      <HeaderLink href="/">首頁</HeaderLink>
      <HeaderLink href="/blog">文章</HeaderLink>
      <HeaderLink href="/about">關於</HeaderLink>
    </div>
    <a href="https://github.com/bargisula" target="_blank" class="github-link" aria-label="GitHub">
      <svg viewBox="0 0 16 16" width="22" height="22" aria-hidden="true">
        <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
      </svg>
    </a>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5em;
    height: 60px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5em;
    text-decoration: none;
    color: rgb(var(--black));
    font-weight: 700;
    font-size: 1.1em;
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--accent);
    color: white;
    border-radius: 8px;
    font-size: 1em;
    font-weight: 700;
  }

  .logo-text {
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 0.5em;
  }

  .github-link {
    color: rgb(var(--gray));
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .github-link:hover {
    color: rgb(var(--black));
  }

  @media (max-width: 480px) {
    .logo-text { display: none; }
    nav { padding: 0 1em; }
  }
</style>
